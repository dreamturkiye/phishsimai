{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile --prod=false && npm run build",
  "installCommand": "pnpm install --no-frozen-lockfile --prod=false",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "server/os/social/{fonts,assets}/**"
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.phishsimai.com" }],
      "destination": "https://phishsimai.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/preview/social/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/unsubscribe",
      "destination": "/api/index.js"
    },
    {
      "source": "/checkout",
      "destination": "/api/index.js"
    },
    {
      "source": "/t/:token",
      "destination": "/api/index.js"
    },
    {
      "source": "/c/:token",
      "destination": "/api/index.js"
    },
    {
      "source": "/landing/:token",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/home.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/terms",
      "destination": "/terms/index.html"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/os/architect/autonomy?action=compute",
      "schedule": "10 0 * * *"
    },
    {
      "path": "/api/os/autonomy-promote",
      "schedule": "20 0 * * *"
    },
    {
      "path": "/api/os/truth-report",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/scheduled/campaign",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/os/sanitize-refill",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/os/sequence",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/os/janet",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/os/metrics-snapshot",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/os/escalation-notify",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/os/founder-brief",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/os/agent-levels",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/os/watchdog",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/os/heartbeat",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/os/discover",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/os/msp-harvest",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/os/outreach-funnel",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/os/trial-nudges",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/os/researcher",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/os/agent-watchdog",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/os/qa-smoke",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/os/sarah-social",
      "schedule": "0 10,16 * * *"
    },
    {
      "path": "/api/scheduled/mia-feedback-digest",
      "schedule": "0 11 * * 1"
    }
  ]
}