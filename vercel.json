{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && npx vite build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "memory": 1024,
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/scheduled/campaign",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/os/sequence",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/os/janet",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/os/watchdog",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/os/heartbeat",
      "schedule": "0 */2 * * *"
    }
  ]
}